# https://editorconfig.org — shared editor defaults, mirroring rustfmt.toml.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.rs]
max_line_length = 100

# Markdown hard line-breaks and vendored corpus/data must keep trailing space.
[*.{md,txt,tsv}]
trim_trailing_whitespace = false

# YAML / JSON (GitHub Actions, VS Code config) are 2-space by convention.
[*.{yml,yaml,json}]
indent_size = 2
