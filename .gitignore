/target
**/*.rs.bk
Cargo.lock.orig
.DS_Store

# wasm-pack default output dir (we build into web/src/lib/pkg; the SvelteKit
# build / node_modules / wasm ignores live in web/.gitignore).
/crates/aozora-proof-wasm/pkg/

